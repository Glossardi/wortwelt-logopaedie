---
/**
 * PageLayout.astro — Standard-Seitenlayout mit Header und Footer
 *
 * Verwendet von allen Seiten außer Landing-Pages mit speziellem Layout.
 */
import BaseLayout from "./BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  robots?: string;
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</BaseLayout>
