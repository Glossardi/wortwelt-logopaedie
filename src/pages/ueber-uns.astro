---
/**
 * ueber-uns.astro — Über-uns-Seite
 *
 * Stellt das Unternehmen, das Team und die Werte vor.
 */
import PageLayout from "@layouts/PageLayout.astro";
import CTA from "@components/CTA.astro";

const values = [
  {
    icon: "🤝",
    title: "Verlässlichkeit",
    text: "Wir halten Termine ein und kommunizieren offen – auch wenn es mal Änderungen gibt.",
  },
  {
    icon: "🎯",
    title: "Qualität",
    text: "Wir arbeiten sauber, normgerecht und nachhaltig. Kein Pfusch, keine Abkürzungen.",
  },
  {
    icon: "💡",
    title: "Kompetenz",
    text: "Unser Team bildet sich kontinuierlich weiter – damit wir immer auf dem neuesten Stand der Technik sind.",
  },
  {
    icon: "💬",
    title: "Ehrlichkeit",
    text: "Wir beraten ehrlich und empfehlen nur, was wirklich sinnvoll ist. Keine unnötigen Zusatzleistungen.",
  },
];

const team = [
  {
    name: "Klaus Mustermann",
    role: "Inhaber & Elektromeister",
    bio: "20+ Jahre Erfahrung in Elektroinstallation und Photovoltaik. Ausgebildet im Handwerk, weitergebildet in Energietechnik.",
  },
  {
    name: "Sandra Mustermann",
    role: "Büro & Kundenbetreuung",
    bio: "Ansprechpartnerin für Terminplanung, Angebote und alle organisatorischen Fragen.",
  },
  {
    name: "Tim Muster",
    role: "Geselle – Schwerpunkt Smart Home",
    bio: "Spezialist für Hausautomation und moderne Vernetzungslösungen.",
  },
];
---

<PageLayout
  title="Über uns"
  description="Lernen Sie Muster Elektrotechnik kennen: Unser Team, unsere Geschichte und unsere Werte als Meisterbetrieb in Musterstadt."
>
  <!-- Seiten-Hero -->
  <section class="page-hero section--surface">
    <div class="container">
      <h1>Über uns</h1>
      <p class="page-hero-intro">
        Ein Familienunternehmen mit Tradition und Leidenschaft für moderne Elektrotechnik.
      </p>
    </div>
  </section>

  <!-- Geschichte -->
  <section class="section">
    <div class="container story-grid">
      <div class="story-content">
        <h2>Unsere Geschichte</h2>
        <p>
          Muster Elektrotechnik wurde 2003 von Klaus Mustermann als Einzelunternehmen gegründet.
          Was als lokaler Elektrikerbetrieb für Privathaushalt begann, hat sich über die Jahre zu
          einem leistungsfähigen Team entwickelt, das Privat- und Gewerbekunden in Musterstadt und
          Umgebung betreut.
        </p>
        <p style="margin-top:1rem">
          Heute sind wir ein Team aus leidenschaftlichen Elektrikern, das täglich daran arbeitet,
          zuverlässige und nachhaltige Lösungen zu liefern – von der klassischen Installation bis
          zur modernen Photovoltaikanlage.
        </p>
        <div class="stats">
          <div class="stat">
            <span class="stat-number">20+</span>
            <span class="stat-label">Jahre Erfahrung</span>
          </div>
          <div class="stat">
            <span class="stat-number">500+</span>
            <span class="stat-label">Projekte abgeschlossen</span>
          </div>
          <div class="stat">
            <span class="stat-number">4,9★</span>
            <span class="stat-label">Google-Bewertung</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Werte -->
  <section class="section section--surface">
    <div class="container">
      <div class="section-header centered">
        <h2 class="section-heading">Unsere Werte</h2>
        <p class="section-intro">Was uns antreibt und wie wir jeden Tag arbeiten.</p>
      </div>
      <ul class="grid-auto values-grid" role="list">
        {values.map((v) => (
          <li class="card value-card">
            <span class="value-icon" aria-hidden="true">{v.icon}</span>
            <h3 class="value-title">{v.title}</h3>
            <p class="value-text">{v.text}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Team -->
  <section class="section">
    <div class="container">
      <div class="section-header centered">
        <h2 class="section-heading">Unser Team</h2>
      </div>
      <ul class="team-grid" role="list">
        {team.map((member) => (
          <li class="card team-card">
            <div class="team-avatar" aria-hidden="true">
              {member.name.charAt(0)}
            </div>
            <h3 class="team-name">{member.name}</h3>
            <p class="team-role">{member.role}</p>
            <p class="team-bio">{member.bio}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTA
    heading="Gemeinsam Ihr Projekt realisieren"
    text="Lernen Sie uns kennen – kontaktieren Sie uns für ein unverbindliches Gespräch."
  />
</PageLayout>

<style>
  .page-hero {
    padding-block: 3rem;
    border-bottom: 1px solid #e2e8f0;
  }
  .page-hero-intro {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
  }

  .story-grid {
    max-width: 800px;
  }
  .story-content p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .stats {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e2e8f0;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .stat-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .values-grid {
    align-items: start;
  }
  .value-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .value-icon { font-size: 1.75rem; }
  .value-title { font-size: 1.05rem; font-weight: 700; }
  .value-text { color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.6; }

  .team-grid {
    list-style: none;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
  }
  .team-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }
  .team-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-on-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    font-weight: 700;
  }
  .team-name { font-size: 1.05rem; font-weight: 700; }
  .team-role { color: var(--color-primary); font-size: 0.9rem; font-weight: 600; }
  .team-bio { color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6; }
</style>
