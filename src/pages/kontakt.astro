---
/**
 * kontakt.astro — Kontaktseite
 *
 * Vollständige Kontaktseite mit Formular und Karte/Anfahrt.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ContactSection from "@components/ContactSection.astro";
import site from "@data/site";
---

<PageLayout
  title="Kontakt"
  description={`Kontaktieren Sie ${site.company} – per Telefon, E-Mail oder über unser Kontaktformular.`}
>
  <section class="page-hero section--surface">
    <div class="container">
      <h1>Kontakt</h1>
      <p class="page-hero-intro">
        Wir freuen uns auf Ihre Anfrage. Nehmen Sie Kontakt auf – wir melden uns schnellstmöglich.
      </p>
    </div>
  </section>

  <ContactSection
    heading="So erreichen Sie uns"
    {/* Für Formspree: formAction="https://formspree.io/f/DEIN-ID" */}
  />
</PageLayout>

<style>
  .page-hero {
    padding-block: 3rem;
    border-bottom: 1px solid #e2e8f0;
  }
  .page-hero-intro {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
  }
</style>
