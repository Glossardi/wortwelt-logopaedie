---
/**
 * Footer.astro — Multi-Column Footer mit Brand, Navigation, Kontakt & Social
 */
import { Icon } from "astro-icon/components";
import site from "@data/site";

const socialLinks = Object.entries(site.social).filter(([_, url]) => url);
const currentYear = new Date().getFullYear();

const socialIconMap: Record<string, string> = {
  facebook: "lucide:facebook",
  instagram: "lucide:instagram",
  linkedin: "lucide:linkedin",
  youtube: "lucide:youtube",
  tiktok: "lucide:music",
  twitter: "lucide:twitter",
  xing: "lucide:briefcase",
  github: "lucide:github",
};
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <!-- Spalte 1: Brand -->
      <div class="footer__brand">
        <span class="footer__logo">{site.company}</span>
        <p class="footer__tagline">{site.tagline}</p>
      </div>

      <!-- Spalte 2: Navigation -->
      <div class="footer__nav">
        <h4 class="footer__heading">Navigation</h4>
        <ul class="footer__links">
          {site.nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Spalte 3: Kontakt + Social -->
      <div class="footer__contact">
        <h4 class="footer__heading">Kontakt</h4>
        <address class="footer__address">
          <a href={`tel:${site.contact.phone.replace(/\s/g, "")}`}>{site.contact.phone}</a>
          <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
        </address>
        {socialLinks.length > 0 && (
          <div class="footer__social">
            {socialLinks.map(([platform, url]) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={platform.charAt(0).toUpperCase() + platform.slice(1)}
                class="footer__social-link"
              >
                <Icon name={socialIconMap[platform] || "lucide:link"} size={20} aria-hidden="true" />
              </a>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Separator + Copyright -->
    <div class="footer__bottom">
      <p class="footer__copyright">&copy; {currentYear} {site.company}</p>
      <nav class="footer__legal">
        <a href="/impressum">Impressum</a>
        <a href="/datenschutz">Datenschutz</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-3xl, 4rem) var(--space-lg, 1.5rem);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl, 2rem);
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 2fr 1fr 1fr;
      gap: var(--space-2xl, 3rem);
    }
  }

  .footer__logo {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-text);
  }

  .footer__tagline {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-top: 0.375rem;
  }

  .footer__heading {
    font-size: 0.875rem;
    font-weight: var(--font-weight-semibold, 600);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide, 0.025em);
    color: var(--color-text-muted);
    margin-bottom: var(--space-md, 1rem);
  }

  .footer__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm, 0.5rem);
  }

  .footer__links a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer__links a:hover {
    color: var(--color-primary);
  }

  .footer__address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs, 0.25rem);
  }

  .footer__address a {
    color: var(--color-text);
    text-decoration: none;
  }

  .footer__address a:hover {
    color: var(--color-primary);
  }

  .footer__social {
    display: flex;
    gap: 0.75rem;
    margin-top: var(--space-md, 1rem);
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    color: var(--color-text-muted);
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .footer__social-link:hover {
    color: var(--color-primary);
    background: var(--color-background);
  }

  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md, 1rem);
    padding-top: var(--space-xl, 2rem);
    margin-top: var(--space-xl, 2rem);
    border-top: 1px solid var(--color-border);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .footer__legal {
    display: flex;
    gap: var(--space-lg, 1.5rem);
  }

  .footer__legal a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .footer__legal a:hover {
    color: var(--color-primary);
  }
</style>
