---
/**
 * AboutTeaser.astro — Kurzvorstellung mit optionalem Bild
 */
import site from "@data/site";

const { about, sectionHeadings } = site;
---

<section class="section section--surface" id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="about-grid">
      <div class="about-content reveal">
        <h2 class="section-heading" id="about-heading">{sectionHeadings.about}</h2>
        <h3 class="about-title">{about.heading}</h3>
        <p class="about-text">{about.text}</p>
      </div>
      {about.image && (
        <div class="about-image reveal">
          <img
            src={about.image}
            alt={about.imageAlt || ""}
            loading="lazy"
            decoding="async"
          />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  .about-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .about-text {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .about-image img {
    width: 100%;
    border-radius: var(--radius-lg);
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }
</style>
