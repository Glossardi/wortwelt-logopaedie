---
/**
 * AboutTeaser.astro — Über-uns-Teaser auf der Startseite
 *
 * Kurze Selbstvorstellung mit optionalem Bild und Link zur Über-uns-Seite.
 */

interface Props {
  heading: string;
  text: string;
  image?: string;
  imageAlt?: string;
  linkLabel?: string;
  linkHref?: string;
}

const {
  heading,
  text,
  image,
  imageAlt = "",
  linkLabel = "Mehr über uns erfahren",
  linkHref = "/ueber-uns",
} = Astro.props;
---

<section class="section about-teaser" aria-labelledby="about-teaser-heading">
  <div class="container about-inner">
    {image && (
      <div class="about-image-wrap">
        <img
          src={image}
          alt={imageAlt}
          class="about-image"
          width="500"
          height="400"
          loading="lazy"
          decoding="async"
        />
      </div>
    )}
    <div class="about-content">
      <h2 id="about-teaser-heading">{heading}</h2>
      <p class="about-text">{text}</p>
      <a href={linkHref} class="btn btn--outline">{linkLabel}</a>
    </div>
  </div>
</section>

<style>
  .about-inner {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .about-inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-image-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .about-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-text {
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 1.05rem;
  }
</style>
