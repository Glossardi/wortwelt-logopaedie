---
/**
 * Testimonials.astro — Kundenstimmen
 *
 * Zeigt Kundenzitate als Karten. Stärkt soziale Bewährtheit.
 */

interface Testimonial {
  quote: string;
  author: string;
  role?: string;
  /** Avatar-Bildpfad (optional) */
  avatar?: string;
}

interface Props {
  testimonials: Testimonial[];
  heading?: string;
}

const { testimonials, heading = "Das sagen unsere Kunden" } = Astro.props;
---

<section class="section" aria-labelledby="testimonials-heading">
  <div class="container">
    <div class="section-header centered">
      <h2 class="section-heading" id="testimonials-heading">{heading}</h2>
    </div>

    <ul class="grid-3 testimonials-grid" role="list">
      {testimonials.map((t) => (
        <li class="card testimonial-card">
          <svg class="quote-icon" aria-hidden="true" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <blockquote class="testimonial-quote">
            <p>"{t.quote}"</p>
          </blockquote>
          <footer class="testimonial-author">
            {t.avatar && (
              <img
                src={t.avatar}
                alt={t.author}
                class="testimonial-avatar"
                width="48"
                height="48"
                loading="lazy"
              />
            )}
            <div>
              <cite class="author-name">{t.author}</cite>
              {t.role && <p class="author-role">{t.role}</p>}
            </div>
          </footer>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .testimonials-grid {
    align-items: start;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-left: 4px solid var(--color-primary);
  }

  .quote-icon {
    color: var(--color-primary);
    opacity: 0.3;
  }

  .testimonial-quote p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    font-style: italic;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
  }

  .testimonial-avatar {
    border-radius: 50%;
    object-fit: cover;
  }

  .author-name {
    display: block;
    font-weight: 700;
    font-style: normal;
    font-size: 0.95rem;
  }

  .author-role {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>
