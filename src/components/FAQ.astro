---
/**
 * FAQ.astro — Häufig gestellte Fragen (Accordion)
 *
 * Reines HTML <details>/<summary> ohne JavaScript-Abhängigkeiten.
 * Funktioniert auch ohne JS. Accessible by default.
 */

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  heading?: string;
  intro?: string;
}

const {
  items,
  heading = "Häufige Fragen",
  intro,
} = Astro.props;
---

<section class="section section--surface" aria-labelledby="faq-heading">
  <div class="container faq-container">
    <div class="section-header">
      <h2 class="section-heading" id="faq-heading">{heading}</h2>
      {intro && <p class="section-intro">{intro}</p>}
    </div>

    <dl class="faq-list">
      {items.map((item) => (
        <div class="faq-item">
          <details>
            <summary class="faq-question">
              <span>{item.question}</span>
              <svg class="faq-icon" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </summary>
            <div class="faq-answer">
              <p>{item.answer}</p>
            </div>
          </details>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .faq-container {
    max-width: 800px;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq-item {
    border: 1px solid #e2e8f0;
    border-radius: var(--radius);
    background: var(--color-background);
    overflow: hidden;
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.125rem 1.25rem;
    cursor: pointer;
    font-weight: 600;
    font-size: 1rem;
    list-style: none;
    user-select: none;
    color: var(--color-text);
    transition: background-color 0.15s ease;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question:hover { background-color: var(--color-surface); }
  .faq-question:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: -2px;
  }

  .faq-icon {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  details[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 1.25rem 1.25rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.95rem;
    border-top: 1px solid #e2e8f0;
    padding-top: 1rem;
  }
</style>
