---
/**
 * CTA.astro — Call-to-Action Sektion
 *
 * Prominenter Handlungsaufruf mit Hintergrundfarbe. Ideal am Seitenende
 * oder zwischen Sektionen.
 */
import site from "@data/site";

interface Props {
  heading?: string;
  text?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
}

const {
  heading = "Bereit anzufangen?",
  text = "Kontaktieren Sie uns noch heute für ein unverbindliches Gespräch.",
  ctaLabel = site.cta.label,
  ctaHref = site.cta.href,
  ctaSecondaryLabel,
  ctaSecondaryHref,
} = Astro.props;
---

<section class="cta-section" aria-label="Call to Action">
  <div class="container cta-inner">
    <div class="cta-content">
      <h2 class="cta-heading">{heading}</h2>
      {text && <p class="cta-text">{text}</p>}
    </div>
    <div class="cta-actions">
      <a href={ctaHref} class="btn btn--primary btn--lg">{ctaLabel}</a>
      {ctaSecondaryLabel && ctaSecondaryHref && (
        <a href={ctaSecondaryHref} class="btn btn--ghost btn--lg">{ctaSecondaryLabel}</a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-section {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    padding-block: 4rem;
  }

  .cta-inner {
    display: flex;
    gap: 2rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .cta-content {
    flex: 1;
    min-width: 200px;
  }

  .cta-heading {
    color: var(--color-on-primary);
    margin-bottom: 0.5rem;
  }

  .cta-text {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.05rem;
    max-width: 55ch;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .btn--lg {
    padding: 0.9rem 2rem;
    font-size: 1.05rem;
  }

  @media (max-width: 600px) {
    .cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
