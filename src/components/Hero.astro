---
/**
 * Hero.astro — Hero-Sektion mit Headline, Subline und CTAs
 */
import site from "@data/site";

const { hero, cta, ctaSecondary } = site;
const hasBackground = !!hero.backgroundImage;
---

<section
  class:list={[
    "hero",
    { "hero--with-bg": hasBackground, "hero--no-image": !hasBackground },
  ]}
>
  {hasBackground && (
    <div class="hero__bg">
      <img src={hero.backgroundImage} alt="" loading="eager" />
    </div>
  )}
  <div class="hero__content container">
    <h1 class="hero__title animate-in">{hero.headline}</h1>
    <p class="hero__subline animate-in animate-in--delay-1">{hero.subline}</p>
    <div class="hero__actions animate-in animate-in--delay-2">
      <a class="btn btn--primary hero__cta-primary" href={cta.href}>{cta.label}</a>
      <a class="btn btn--outline hero__cta-secondary" href={ctaSecondary.href}>{ctaSecondary.label}</a>
    </div>
  </div>
</section>

<style>
  /* ── Base ─────────────────────────────────────────────── */

  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 85vh;
    padding-block: 6rem 4rem;
    overflow: hidden;
  }

  /* ── No-image variant: animated gradient background ──── */

  .hero--no-image {
    background: linear-gradient(
      135deg,
      var(--color-background) 0%,
      var(--color-surface) 50%,
      var(--color-background) 100%
    );
    background-size: 200% 200%;
    animation: gradientShift 15s ease infinite;
  }

  @keyframes gradientShift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero--no-image {
      animation: none;
      background-size: 100% 100%;
    }
  }

  /* ── Background-image variant ────────────────────────── */

  .hero--with-bg {
    background: none;
    color: #fff;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 0, 0, 0.4) 100%
    );
  }

  /* ── Content ─────────────────────────────────────────── */

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: min(720px, 90%);
  }

  /* ── Title ───────────────────────────────────────────── */

  .hero__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .hero--no-image .hero__title {
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero--with-bg .hero__title {
    color: #fff;
  }

  /* ── Subline ─────────────────────────────────────────── */

  .hero__subline {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 560px;
    margin-bottom: 2rem;
  }
  .hero--with-bg .hero__subline { color: rgba(255, 255, 255, 0.9); }

  /* ── CTA buttons ─────────────────────────────────────── */

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero__cta-primary {
    font-size: 1.1rem;
    padding: 0.875rem 2.25rem;
  }

  .hero__cta-secondary {
    font-size: 0.95rem;
    padding: 0.625rem 1.5rem;
  }

  .hero--with-bg .hero__cta-secondary {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.6);
  }
  .hero--with-bg .hero__cta-secondary:hover {
    background: #fff;
    color: var(--color-text);
    border-color: #fff;
  }

  /* ── Mobile ──────────────────────────────────────────── */

  @media (max-width: 640px) {
    .hero { min-height: 70vh; padding-block: 4rem 3rem; }
    .hero__actions { flex-direction: column; }
    .hero__cta-primary,
    .hero__cta-secondary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
