---
/**
 * ContactSection.astro — Kontaktsektion
 *
 * Zeigt Kontaktdaten und ein einfaches Kontaktformular.
 * Standard-Aktion: mailto-Fallback. Für Formspree/Basin den action-Prop setzen.
 *
 * Formular-Strategie:
 * - Default: mailto-Link (kein Backend nötig)
 * - Formspree: action="https://formspree.io/f/DEIN-ID" setzen
 * - Cloudflare Forms: action="" und data-cf-turnstile ergänzen
 */
import site from "@data/site";

interface Props {
  /** Formular action-URL. Leer = mailto-Fallback. */
  formAction?: string;
  heading?: string;
}

const {
  formAction = "",
  heading = "Kontakt aufnehmen",
} = Astro.props;

const mailtoHref = `mailto:${site.contact.email}?subject=Anfrage über die Website`;
---

<section class="section contact-section" aria-labelledby="contact-heading">
  <div class="container contact-grid">
    <!-- Kontaktinformationen -->
    <div class="contact-info">
      <h2 id="contact-heading">{heading}</h2>
      <p class="contact-intro">
        Sie haben Fragen oder möchten ein Angebot? Wir freuen uns auf Ihre Nachricht.
      </p>

      <address class="contact-details">
        <div class="contact-item">
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.29 6.29l.61-.61a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <a href={`tel:${site.contact.phone.replace(/\s/g, "")}`}>{site.contact.phone}</a>
        </div>
        <div class="contact-item">
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
          <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
        </div>
        <div class="contact-item">
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          <span>{site.contact.address.street}, {site.contact.address.zip} {site.contact.address.city}</span>
        </div>
      </address>

      {site.openingHours.length > 0 && (
        <div class="opening-hours">
          <h3>Öffnungszeiten</h3>
          <dl class="hours-list">
            {site.openingHours.map((item) => (
              <>
                <dt>{item.days}</dt>
                <dd>{item.hours}</dd>
              </>
            ))}
          </dl>
        </div>
      )}
    </div>

    <!-- Kontaktformular -->
    <div class="contact-form-wrap">
      {formAction ? (
        <!-- Externer Form-Provider (z. B. Formspree) -->
        <form
          action={formAction}
          method="POST"
          class="contact-form"
          novalidate
        >
          <div class="form-group">
            <label for="name">Name <span aria-hidden="true">*</span></label>
            <input type="text" id="name" name="name" required autocomplete="name" placeholder="Max Mustermann" />
          </div>
          <div class="form-group">
            <label for="email">E-Mail <span aria-hidden="true">*</span></label>
            <input type="email" id="email" name="email" required autocomplete="email" placeholder="max@beispiel.de" />
          </div>
          <div class="form-group">
            <label for="phone">Telefon (optional)</label>
            <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="+49 123 456789" />
          </div>
          <div class="form-group">
            <label for="message">Nachricht <span aria-hidden="true">*</span></label>
            <textarea id="message" name="message" rows="5" required placeholder="Wie können wir Ihnen helfen?"></textarea>
          </div>
          <p class="form-privacy">
            Mit dem Absenden stimmen Sie unserer <a href="/datenschutz">Datenschutzerklärung</a> zu.
          </p>
          <button type="submit" class="btn btn--primary">Nachricht senden</button>
        </form>
      ) : (
        <!-- Mailto-Fallback -->
        <div class="mailto-cta card">
          <h3>Direkt schreiben</h3>
          <p>Senden Sie uns eine E-Mail – wir antworten innerhalb eines Werktages.</p>
          <a href={mailtoHref} class="btn btn--primary">E-Mail schreiben</a>
          <p class="form-hint">
            <strong>Hinweis für Entwickler:</strong> Für ein Kontaktformular setzen Sie den
            <code>formAction</code>-Prop auf Ihre Formspree-/Basin-URL.
          </p>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1.2fr;
    }
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-intro {
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .contact-details {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-text);
  }
  .contact-item svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-primary);
  }
  .contact-item a {
    color: var(--color-text);
    text-decoration: none;
  }
  .contact-item a:hover { color: var(--color-primary); }

  .opening-hours h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .hours-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.2rem 1rem;
    font-size: 0.9rem;
  }
  .hours-list dt { color: var(--color-text-muted); }
  .hours-list dd { color: var(--color-text); }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .form-group input,
  .form-group textarea {
    padding: 0.75rem 1rem;
    border: 1.5px solid #cbd5e1;
    border-radius: var(--radius);
    font-size: 1rem;
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-background);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    width: 100%;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 20%, transparent);
  }
  .form-group textarea { resize: vertical; }

  .form-privacy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .mailto-cta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .form-hint {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    border-top: 1px dashed #e2e8f0;
    padding-top: 0.75rem;
  }
  .form-hint code {
    background: var(--color-surface);
    padding: 0.1em 0.3em;
    border-radius: 3px;
    font-size: 0.85em;
  }
</style>
